APP_NAME=SurveySwap
APP_ENV=local
APP_KEY=                        # generate dengan: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack

# ==============================
# DATABASE — sesuaikan dengan setup lo
# ==============================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=surveyswap
DB_USERNAME=root
DB_PASSWORD=                    # kosong kalau XAMPP default, isi kalau Laragon

# ==============================
# SANCTUM
# ==============================
SANCTUM_STATEFUL_DOMAINS=localhost:5500,localhost:3000,127.0.0.1:5500

# ==============================
# STORAGE — untuk foto & file upload
# ==============================
FILESYSTEM_DISK=public
